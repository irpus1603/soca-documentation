{
  "id": null,
  "uid": "soca-ppe-safety",
  "title": "SOCA — PPE & Safety Compliance",
  "tags": ["soca", "ppe", "safety"],
  "timezone": "Asia/Jakarta",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m"]
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "postgres",
        "label": "Data Source",
        "hide": 0,
        "refresh": 1,
        "current": {}
      },
      {
        "name": "edge",
        "type": "query",
        "label": "Edge",
        "datasource": { "type": "postgres", "uid": "${datasource}" },
        "query": "SELECT DISTINCT edge_name FROM app_alert WHERE edge_name <> '' ORDER BY 1",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "hide": 0,
        "current": {}
      },
      {
        "name": "camera",
        "type": "query",
        "label": "Camera / Zone",
        "datasource": { "type": "postgres", "uid": "${datasource}" },
        "query": "SELECT DISTINCT COALESCE(NULLIF(camera_name,''), camera_id) FROM app_alert WHERE alert_category = 'PPE' ORDER BY 1",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "hide": 0,
        "current": {}
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "type": "stat",
      "title": "Total PPE Violations (Selected Range)",
      "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${datasource}" },
          "rawSql": "SELECT COUNT(*) AS value FROM app_alert WHERE $__timeFilter(timestamp) AND alert_category = 'PPE'",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Cameras with Violations",
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${datasource}" },
          "rawSql": "SELECT COUNT(DISTINCT camera_id) AS value FROM app_alert WHERE $__timeFilter(timestamp) AND alert_category = 'PPE'",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "orange", "value": null }]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Total Non-Compliant Persons",
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${datasource}" },
          "rawSql": "SELECT SUM(in_roi_count) AS value FROM app_alert WHERE $__timeFilter(timestamp) AND alert_category = 'PPE'",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "red", "value": null }]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Edges with Violations",
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "postgres", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${datasource}" },
          "rawSql": "SELECT COUNT(DISTINCT edge_name) AS value FROM app_alert WHERE $__timeFilter(timestamp) AND alert_category = 'PPE'",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "semi-dark-orange", "value": null }]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Daily PPE Violation Trend",
      "id": 5,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${datasource}" },
          "rawSql": "SELECT\n    $__timeGroupAlias(timestamp, $__interval),\n    COUNT(*) AS violations,\n    SUM(in_roi_count) AS total_non_compliant\nFROM app_alert\nWHERE $__timeFilter(timestamp)\n  AND alert_category = 'PPE'\nGROUP BY 1\nORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }
        },
        "overrides": []
      }
    },
    {
      "type": "barchart",
      "title": "Violations by Camera / Zone",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "postgres", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${datasource}" },
          "rawSql": "SELECT\n    COALESCE(NULLIF(camera_name, ''), camera_id) AS zone,\n    edge_name,\n    COUNT(*) AS violation_count,\n    ROUND(AVG(in_roi_count), 1) AS avg_non_compliant\nFROM app_alert\nWHERE $__timeFilter(timestamp)\n  AND alert_category = 'PPE'\nGROUP BY camera_id, camera_name, edge_name\nORDER BY violation_count DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "type": "piechart",
      "title": "Non-Compliant PPE Item Breakdown",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "postgres", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${datasource}" },
          "rawSql": "SELECT\n    kv.key AS ppe_item,\n    SUM((kv.value)::integer) AS total_detected,\n    COUNT(DISTINCT a.id) AS alert_count\nFROM app_alert a,\n     jsonb_each(a.cls_name_summary) kv\nWHERE $__timeFilter(a.timestamp)\n  AND a.alert_category = 'PPE'\nGROUP BY kv.key\nORDER BY total_detected DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "list", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "type": "table",
      "title": "Recent PPE Violations",
      "id": 8,
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "postgres", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${datasource}" },
          "rawSql": "SELECT\n    (timestamp AT TIME ZONE 'Asia/Jakarta') AS local_time,\n    COALESCE(NULLIF(camera_name, ''), camera_id) AS zone,\n    edge_name,\n    rule_name,\n    in_roi_count AS non_compliant_count,\n    snapshot_message\nFROM app_alert\nWHERE $__timeFilter(timestamp)\n  AND alert_category = 'PPE'\nORDER BY timestamp DESC\nLIMIT 500",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {},
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "non_compliant_count" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "yellow", "value": 1 },
                    { "color": "orange", "value": 3 },
                    { "color": "red", "value": 5 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      }
    }
  ]
}
