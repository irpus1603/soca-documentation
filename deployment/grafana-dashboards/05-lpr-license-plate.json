{
  "id": null,
  "uid": "soca-lpr",
  "title": "SOCA — LPR (License Plate Recognition)",
  "tags": ["soca", "lpr", "vehicle"],
  "timezone": "Asia/Jakarta",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m"]
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "postgres",
        "label": "Data Source",
        "hide": 0,
        "refresh": 1,
        "current": {}
      },
      {
        "name": "edge",
        "type": "query",
        "label": "Edge",
        "datasource": { "type": "postgres", "uid": "${datasource}" },
        "query": "SELECT DISTINCT edge_name FROM app_alert WHERE edge_name <> '' ORDER BY 1",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "hide": 0,
        "current": {}
      },
      {
        "name": "camera",
        "type": "query",
        "label": "Camera",
        "datasource": { "type": "postgres", "uid": "${datasource}" },
        "query": "SELECT DISTINCT COALESCE(NULLIF(camera_name,''), camera_id) FROM app_alert WHERE alert_category = 'LPR' ORDER BY 1",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "hide": 0,
        "current": {}
      },
      {
        "name": "plate_search",
        "type": "textbox",
        "label": "Plate Number Search",
        "hide": 0,
        "current": { "value": "" }
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "type": "stat",
      "title": "Total LPR Events",
      "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${datasource}" },
          "rawSql": "SELECT COUNT(*) AS value FROM app_alert WHERE $__timeFilter(timestamp) AND alert_category = 'LPR'",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Unique Plates Detected",
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${datasource}" },
          "rawSql": "SELECT COUNT(DISTINCT plate ->> 'plate_number') AS value\nFROM app_alert a, jsonb_array_elements(a.lpr_plates) plate\nWHERE $__timeFilter(a.timestamp)\n  AND a.alert_category = 'LPR'\n  AND (plate ->> 'plate_number') <> ''",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Active LPR Cameras",
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${datasource}" },
          "rawSql": "SELECT COUNT(DISTINCT camera_id) AS value FROM app_alert WHERE $__timeFilter(timestamp) AND alert_category = 'LPR'",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Avg Confidence (%)",
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "postgres", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${datasource}" },
          "rawSql": "SELECT ROUND(AVG((plate ->> 'plate_confidence')::numeric * 100), 1) AS value\nFROM app_alert a, jsonb_array_elements(a.lpr_plates) plate\nWHERE $__timeFilter(a.timestamp)\n  AND a.alert_category = 'LPR'\n  AND (plate ->> 'plate_confidence') IS NOT NULL",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "text": {}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "green", "value": 80 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Daily LPR Detections",
      "id": 5,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${datasource}" },
          "rawSql": "SELECT\n    $__timeGroupAlias(timestamp, $__interval),\n    COUNT(*) AS detection_events\nFROM app_alert\nWHERE $__timeFilter(timestamp)\n  AND alert_category = 'LPR'\nGROUP BY 1\nORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 15, "lineWidth": 2, "showPoints": "never" }
        },
        "overrides": []
      }
    },
    {
      "type": "barchart",
      "title": "Plates by Camera",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "postgres", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${datasource}" },
          "rawSql": "SELECT\n    COALESCE(NULLIF(a.camera_name, ''), a.camera_id) AS camera,\n    a.edge_name,\n    COUNT(DISTINCT plate ->> 'plate_number') AS unique_plates,\n    COUNT(*) AS total_reads\nFROM app_alert a,\n     jsonb_array_elements(a.lpr_plates) plate\nWHERE $__timeFilter(a.timestamp)\n  AND a.alert_category = 'LPR'\n  AND (plate ->> 'plate_number') <> ''\nGROUP BY a.camera_id, a.camera_name, a.edge_name\nORDER BY total_reads DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "type": "table",
      "title": "Most Frequent Plates (Top 50)",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "postgres", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${datasource}" },
          "rawSql": "SELECT\n    plate ->> 'plate_number' AS plate_number,\n    COUNT(*) AS appearances,\n    MIN(a.timestamp AT TIME ZONE 'Asia/Jakarta') AS first_seen,\n    MAX(a.timestamp AT TIME ZONE 'Asia/Jakarta') AS last_seen,\n    COUNT(DISTINCT a.camera_id) AS camera_count\nFROM app_alert a,\n     jsonb_array_elements(a.lpr_plates) plate\nWHERE $__timeFilter(a.timestamp)\n  AND a.alert_category = 'LPR'\n  AND (plate ->> 'plate_number') <> ''\nGROUP BY plate ->> 'plate_number'\nORDER BY appearances DESC\nLIMIT 50",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {},
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "appearances" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 5 },
                    { "color": "red", "value": 20 }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "table",
      "title": "All Detected Plates",
      "id": 8,
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "postgres", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${datasource}" },
          "rawSql": "SELECT\n    (a.timestamp AT TIME ZONE 'Asia/Jakarta') AS local_time,\n    COALESCE(NULLIF(a.camera_name, ''), a.camera_id) AS camera,\n    a.edge_name,\n    plate ->> 'plate_number' AS plate_number,\n    plate ->> 'plate_expiry' AS expiry,\n    ROUND((plate ->> 'plate_confidence')::numeric * 100, 1) AS confidence_pct\nFROM app_alert a,\n     jsonb_array_elements(a.lpr_plates) plate\nWHERE $__timeFilter(a.timestamp)\n  AND a.alert_category = 'LPR'\n  AND (plate ->> 'plate_number') IS NOT NULL\n  AND (plate ->> 'plate_number') <> ''\nORDER BY a.timestamp DESC\nLIMIT 1000",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {},
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "confidence_pct" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "yellow", "value": 60 },
                    { "color": "green", "value": 80 }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "table",
      "title": "Plate Search (use $plate_search variable above)",
      "id": 9,
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 32 },
      "datasource": { "type": "postgres", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${datasource}" },
          "rawSql": "SELECT\n    (a.timestamp AT TIME ZONE 'Asia/Jakarta') AS local_time,\n    COALESCE(NULLIF(a.camera_name, ''), a.camera_id) AS camera,\n    a.edge_name,\n    plate ->> 'plate_number' AS plate_number,\n    plate ->> 'plate_expiry' AS expiry,\n    ROUND((plate ->> 'plate_confidence')::numeric * 100, 1) AS confidence_pct\nFROM app_alert a,\n     jsonb_array_elements(a.lpr_plates) plate\nWHERE $__timeFilter(a.timestamp)\n  AND a.alert_category = 'LPR'\n  AND (plate ->> 'plate_number') ILIKE '%${plate_search}%'\nORDER BY a.timestamp DESC\nLIMIT 200",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {},
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "confidence_pct" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "yellow", "value": 60 },
                    { "color": "green", "value": 80 }
                  ]
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
